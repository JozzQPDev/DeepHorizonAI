---
// src/pages/remote.astro
// Página para capturar la cámara del móvil y vincularla al monitor
import Layout from '../layouts/Layout.astro';
---
<Layout>    
    <div class="min-h-screen flex flex-col items-center justify-center p-6 overflow-hidden bg-[#0a0c0e]">
    <!-- Carga de PeerJS para enviar video -->
    <script is:inline src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js"></script>
    
    <div id="setup-view" class="w-full max-w-md text-center space-y-8 animate-in fade-in zoom-in duration-500">
        <div class="relative inline-block">
            <div class="absolute inset-0 bg-blue-500 blur-2xl opacity-20"></div>
            <div class="relative w-24 h-24 bg-blue-500/10 border border-blue-500/30 rounded-3xl flex items-center justify-center mx-auto">
                <i class="fa-solid fa-mobile-screen-button text-4xl text-blue-400"></i>
            </div>
        </div>
        
        <div>
            <h1 class="text-2xl font-black uppercase tracking-widest mb-2">Vincular Cámara</h1>
            <p class="text-xs text-gray-500 leading-relaxed">
                Vas a compartir la cámara de este dispositivo con el monitor <br>
                <span id="monitor-id" class="text-blue-400 font-bold px-2 py-0.5 bg-blue-500/10 rounded mt-2 inline-block">...</span>
            </p>
        </div>

        <button id="start-btn" class="w-full py-5 bg-blue-600 hover:bg-blue-500 text-white rounded-2xl font-black text-xs tracking-[0.2em] transition-all active:scale-95 shadow-2xl shadow-blue-900/40">
            ACTIVAR CÁMARA
        </button>
        
        <p class="text-[10px] text-gray-600 uppercase tracking-widest">Deep Horizon AI Safety Monitor</p>
    </div>

    <div id="camera-view" class="hidden fixed inset-0 bg-black flex-col">
        <video id="preview" autoplay playsinline muted class="w-full h-full object-cover"></video>
        
        <!-- Capas de Gradiente para legibilidad de UI -->
        <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/80"></div>
        
        <div class="absolute top-6 left-6 right-6 flex items-center justify-between z-10">
            <div class="flex items-center gap-2">
                <!-- Transmisión Status -->
                <div class="flex items-center gap-2 px-3 py-1.5 bg-red-500/20 border border-red-500/30 rounded-2xl backdrop-blur-xl shadow-2xl">
                    <span class="w-2 h-2 bg-red-500 rounded-full animate-pulse shadow-[0_0_8px_rgba(239,68,68,0.8)]"></span>
                    <span class="text-[10px] font-black text-red-500 font-mono uppercase tracking-wider">LIVE</span>
                </div>

                <!-- Cronómetro -->
                <div class="flex items-center gap-2 px-3 py-1.5 bg-white/5 border border-white/10 rounded-2xl backdrop-blur-xl shadow-2xl text-white/70">
                    <i class="fa-regular fa-clock text-[10px] text-blue-400"></i>
                    <span id="timer-text" class="text-[10px] font-black font-mono uppercase tracking-wider">00:00</span>
                </div>
            </div>

            <!-- Resolución de Video -->
            <div class="flex items-center gap-2 px-3 py-1.5 bg-white/5 border border-white/10 rounded-2xl backdrop-blur-xl shadow-2xl">
                <i class="fa-solid fa-expand text-blue-400 text-[10px]"></i>
                <span id="res-text" class="text-[10px] font-black text-white/70 font-mono uppercase tracking-wider">0x0</span>
            </div>
        </div>

        <!-- Controles Inferiores -->
        <div class="absolute bottom-10 left-6 right-6 flex flex-col items-center gap-4 z-10">
            <div class="px-4 py-2 bg-black/40 border border-white/5 rounded-full backdrop-blur-md mb-2">
                <p class="text-[9px] text-gray-400 uppercase tracking-[0.3em] font-medium">Vinculado a: <span class="id-display text-blue-400 font-black"></span></p>
            </div>

            <div class="w-full max-w-md grid grid-cols-2 gap-3">
                <button id="flip-camera-btn" class="flex flex-col items-center justify-center gap-2 py-5 bg-white/5 hover:bg-white/10 text-white rounded-3xl border border-white/10 backdrop-blur-xl transition-all active:scale-95 group">
                    <i class="fa-solid fa-camera-rotate text-lg text-white/60 group-hover:text-white group-hover:rotate-180 transition-all duration-500"></i>
                    <span id="flip-label" class="text-[9px] font-black uppercase tracking-widest">Cámara Frontal</span>
                </button>
                
                <button id="stop-btn" class="flex flex-col items-center justify-center gap-2 py-5 bg-red-500/10 hover:bg-red-500/20 text-red-400 rounded-3xl border border-red-500/20 backdrop-blur-xl transition-all active:scale-95 group">
                    <i class="fa-solid fa-power-off text-lg text-red-500/60 group-hover:text-red-500 transition-colors"></i>
                    <span class="text-[9px] font-black uppercase tracking-widest">Finalizar</span>
                </button>
            </div>
        </div>
    </div>
    <script>
        const urlParams = new URLSearchParams(window.location.search);
        const monitorId = urlParams.get('id');

        // Normalización robusta:
        // - QR puede enviar idPrefix tipo "det1-" o "det2-"
        // - El monitor PeerJS debería escuchar "ppe-monitor-<número>"
        const idClean = monitorId?.toString().match(/\d+/)?.[0] || monitorId?.toString().replace(/[^a-zA-Z0-9]/g, '') || '';
        const peerMonitorId = `ppe-monitor-${idClean}`;
        
        const setupView = document.getElementById('setup-view') as HTMLElement;
        const cameraView = document.getElementById('camera-view') as HTMLElement;
        const startBtn = document.getElementById('start-btn') as HTMLButtonElement;
        const stopBtn = document.getElementById('stop-btn') as HTMLButtonElement;
        const flipCameraBtn = document.getElementById('flip-camera-btn') as HTMLButtonElement;
        const preview = document.getElementById('preview') as HTMLVideoElement;
        const idDisplays = document.querySelectorAll('.id-display, #monitor-id');

        // Mostrar el ID del monitor en la UI (asegurando que los elementos existan)
        idDisplays.forEach(el => el.textContent = monitorId || 'Monitor');

        // Listener para actualizar la resolución dinámicamente (cambios de cámara u orientación)
        preview.addEventListener('resize', () => {
            const resText = document.getElementById('res-text');
            if (resText && preview.videoWidth > 2) {
                resText.textContent = `${preview.videoWidth}x${preview.videoHeight}`;
            }
        });

        let stream: MediaStream | null = null;
        let peerInstance: any = null; // Persistencia de la instancia de Peer
        let currentFacingMode: 'user' | 'environment' = 'environment'; // Iniciar con la cámara trasera por defecto

        // Lógica del Cronómetro
        let timerInterval: number | null = null;
        let startTime = 0;

        const startTimer = () => {
            if (timerInterval) return;
            startTime = Date.now();
            timerInterval = window.setInterval(() => {
                const elapsed = Date.now() - startTime;
                const m = Math.floor(elapsed / 60000);
                const s = Math.floor((elapsed % 60000) / 1000);
                const timerText = document.getElementById('timer-text');
                if (timerText) {
                    timerText.textContent = `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
                }
            }, 1000);
        };

        // Inicializar peerInstance temprano para manejar posibles flipCamera antes del clic de startBtn
        peerInstance = new (window as any).Peer(); // ID aleatorio para el móvil
        peerInstance.on('error', (err: any) => console.error("Error en PeerJS móvil:", err));

        // Función centralizada para llamar al monitor
        const startPeerCall = (retryCount = 0) => {
            const MAX_RETRIES = 10; // Try for up to 5 seconds (10 * 500ms)
            const Peer = (window as any).Peer;
            if (Peer && monitorId && stream) {
                // Check if video track is active and ready
                const videoTrack = stream.getVideoTracks()[0];
                if (!videoTrack || videoTrack.readyState !== 'live' || videoTrack.muted || !videoTrack.enabled) {
                    if (retryCount < MAX_RETRIES) {
                        console.warn(`[Remote] Video track not ready, retrying... (${retryCount + 1}/${MAX_RETRIES})`);
                        setTimeout(() => startPeerCall(retryCount + 1), 500);
                        return;
                    } else {
                        console.error("[Remote] Failed to get a live video track after multiple retries.");
                        alert("Error: El stream de video no está listo para ser enviado.");
                        return;
                    }
                }

                const callMonitor = () => {
                    console.log("Iniciando transmisión hacia:", peerMonitorId);
                    peerInstance.call(peerMonitorId, stream); // Send the stream
                };

                if (peerInstance.open) callMonitor();
                else peerInstance.on('open', callMonitor);
            }
        };

        startBtn.onclick = async () => {
            try {
                stream = await navigator.mediaDevices.getUserMedia({ 
                    // Limitamos a 1280x720 para máxima estabilidad en transmisión remota
                    video: { facingMode: currentFacingMode, width: { ideal: 1280 }, height: { ideal: 720 } },
                    audio: false 
                });
                
                if (preview) preview.srcObject = stream;
                if (preview) preview.play().catch(console.error);
                
                // Esperar a que la cámara del móvil tenga resolución antes de llamar al monitor
                const checkCameraWarmup = () => {
                  if (preview && preview.videoWidth > 2) {
                    if (setupView) setupView.classList.add('hidden');
                    if (cameraView) {
                        cameraView.classList.remove('hidden');
                        cameraView.classList.add('flex');
                    }
                    // Sincronizar resolución al iniciar
                    const resText = document.getElementById('res-text');
                    if (resText) {
                        resText.textContent = `${preview.videoWidth}x${preview.videoHeight}`;
                    }
                    startPeerCall();
                    startTimer();
                  } else {
                    setTimeout(checkCameraWarmup, 100);
                  }
                };
                checkCameraWarmup();

            } catch (err) {
                alert("Error: No se pudo acceder a la cámara. Por favor permite el acceso en los ajustes de tu navegador.");
                console.error(err);
            }
        };

        if (stopBtn) stopBtn.onclick = () => {
            if (stream) stream.getTracks().forEach((t: MediaStreamTrack) => t.stop());
            if (timerInterval) clearInterval(timerInterval);
            window.location.reload();
            if (peerInstance) {
                peerInstance.destroy();
                peerInstance = null;
            }
        };

        if (flipCameraBtn) flipCameraBtn.onclick = async () => {
            if (stream) {
                stream.getTracks().forEach(track => track.stop());
            }
            currentFacingMode = currentFacingMode === 'environment' ? 'user' : 'environment';
            const flipLabel = document.getElementById('flip-label');
            if (flipLabel) {
                flipLabel.textContent = currentFacingMode === 'environment' ? 'Cámara Frontal' : 'Cámara Trasera';
            }
            try {
                stream = await navigator.mediaDevices.getUserMedia({
                    video: { facingMode: currentFacingMode, width: { ideal: 1280 }, height: { ideal: 720 } },
                    audio: false
                });
                if (preview) preview.srcObject = stream;
                if (preview) preview.play().catch(console.error); // Ensure new stream plays locally

                // Re-call the monitor with the new stream after a short delay
                // to ensure the new stream is fully active
                setTimeout(startPeerCall, 500);
            } catch (err) {
                alert("Error al cambiar de cámara.");
                currentFacingMode = currentFacingMode === 'environment' ? 'user' : 'environment'; 
                if (flipLabel) {
                    flipLabel.textContent = currentFacingMode === 'environment' ? 'Cámara Frontal' : 'Cámara Trasera';
                }
            }
        };
    </script>
</Layout>
