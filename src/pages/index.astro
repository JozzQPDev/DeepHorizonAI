---
import Layout from '../layouts/Layout.astro';
import Detector from '../components/Detector.astro';
import Toolbar from '../components/Toolbar.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import HistoryModal from '../components/HistoryModal.astro';
import "../styles/global.css";
---

<Layout>
<div class="relative h-screen bg-[#0a0c0e] text-white overflow-hidden flex flex-col lg:flex-row"> 
  <!-- Contenedor de Notificaciones (Toasts) para móvil -->
  <div id="notification-container" class="fixed top-14 left-4 z-1000 flex flex-col gap-2 pointer-events-none lg:hidden"></div>
  
  <!-- Sidebar: Ahora es un hijo directo del layout para evitar recortes en móvil -->
  <Sidebar />

  <!-- Área de Contenido (Video y Toolbar) -->
  <div class="flex-1 flex flex-col min-h-0 border-r border-white/5 relative z-0"> 
    <Toolbar />

    <div id="drop-zone" class="flex-1 relative overflow-y-auto bg-black/50 grid grid-cols-1 gap-1 p-1 transition-all duration-300">
      {Array.from({ length: 10 }).map((_, i) => (
        <div id={`slot-detector-${i + 1}`} class={`detector-slot w-full h-full overflow-hidden rounded-lg border border-white/5 ${i > 0 ? 'hidden' : ''}`}>
          <Detector idPrefix={`det${i + 1}-`} />
        </div>
      ))}
    </div>
    <div class="shrink-0">
      <Footer />
    </div>
  </div>



<HistoryModal />

<script>
  import { MonitorController } from "../lib/monitor-controller";
  import { FilterController } from "../lib/filter-controller";
  
  const monitor = new MonitorController();
  new FilterController();
  monitor.setupCollapsibles();

  window.addEventListener("ppe:toggleMode", () => monitor.clearStats());
  window.addEventListener("ppe:sourceChange", () => monitor.clearStats());
  
  // Persistencia de teléfono
  const phoneInput = document.getElementById("report-phone") as HTMLInputElement;
  if (phoneInput) {
    phoneInput.value = localStorage.getItem("ppe_report_phone") || "";
    phoneInput.oninput = () => localStorage.setItem("ppe_report_phone", phoneInput.value);
  }

  // La lógica de historial ahora se maneja internamente en monitor-controller.ts

  // Lógica para agregar/quitar pantallas
  let activeScreens = 1;
  const btnAdd = document.getElementById('btn-add-screen');
  const btnRemove = document.getElementById('btn-remove-screen');
  const countText = document.getElementById('active-count-text');
  const dropZone = document.getElementById('drop-zone');

  const updateScreensUI = () => {
    const allSlots = Array.from(document.querySelectorAll('.detector-slot')) as HTMLElement[];
    const visibleSlots = allSlots.filter(s => !s.classList.contains('hidden'));
    activeScreens = visibleSlots.length;
    
    // Limpiar clases de posicionamiento en todos los slots
    allSlots.forEach(slot => {
      slot.classList.remove('col-span-1', 'col-span-2', 'col-span-3', 'row-span-1', 'row-span-2', 'row-span-3');
    });

    if (dropZone) {
      // Limpiar configuración de grid
      dropZone.classList.remove(
        'grid-cols-1', 'grid-cols-2', 'grid-cols-3', 'grid-cols-4', 
        'grid-rows-1', 'grid-rows-2', 'grid-rows-3',
        'md:grid-cols-2', 'lg:grid-cols-2', 'xl:grid-cols-3'
      );

      // Lógica de Layout dinámico
      const isMobile = window.innerWidth < 768;

      if (activeScreens === 1 || isMobile) {
        dropZone.classList.add('grid-cols-1');
      } 
      else if (activeScreens === 2) {
        dropZone.classList.add('grid-cols-1', 'md:grid-cols-2');
      } 
      else if (activeScreens === 3) {
        dropZone.classList.add('grid-cols-2', 'grid-rows-2');
        visibleSlots[0].classList.add('col-span-2');
      } 
      else if (activeScreens === 4) {
        dropZone.classList.add('grid-cols-2', 'grid-rows-2');
      } 
      else if (activeScreens <= 6) {
        dropZone.classList.add('grid-cols-3', 'grid-rows-2');
        visibleSlots[0].classList.add('col-span-2', 'row-span-2');
      } 
      else if (activeScreens <= 9) {
        dropZone.classList.add('grid-cols-3', 'grid-rows-3');
      } 
      else {
        dropZone.classList.add('grid-cols-4');
        visibleSlots[0].classList.add('col-span-2', 'row-span-2');
      }
    }

    // Ocultar botones de cierre si solo hay una pantalla
    const closeButtons = document.querySelectorAll('[id$="close-btn"]');
    closeButtons.forEach(btn => {
      (btn as HTMLElement).style.display = activeScreens > 1 ? 'flex' : 'none';
    });

    if (countText) countText.textContent = activeScreens.toString();
    
    // Actualizar estado de botones
    if (btnAdd) (btnAdd as HTMLButtonElement).disabled = activeScreens >= 10;
    if (btnRemove) {
      const isDisabled = activeScreens <= 1;
      (btnRemove as HTMLButtonElement).disabled = isDisabled;
      btnRemove.classList.toggle('opacity-50', isDisabled);
      btnRemove.classList.toggle('cursor-not-allowed', isDisabled);
    }
  };

  // Listener para cerrar un slot específico
  window.addEventListener('ppe:removeSlot', (e: any) => {
    const containerId = e.detail; // ej: "det2--detector-container"
    const slotId = containerId.replace('detector-container', '').replace('det', 'slot-detector-').replace('--', '');
    // Limpiamos el ID para que coincida con slot-detector-X
    const numericId = containerId.match(/\d+/)?.[0];
    const slot = document.getElementById(`slot-detector-${numericId}`);
    
    if (slot && activeScreens > 1) {
      // Detener la fuente de video del Custom Element antes de ocultar el slot
      const ppeDetectorElement = slot.querySelector('ppe-detector') as any; // Casteamos a 'any' para acceder al método público
      if (ppeDetectorElement && typeof ppeDetectorElement.stopDetectorSource === 'function') {
        ppeDetectorElement.stopDetectorSource();
      }
      slot.classList.add('hidden');
      updateScreensUI();
    }
  });

  btnAdd?.addEventListener('click', () => { 
    if (activeScreens < 10) { 
      const nextSlot = Array.from(document.querySelectorAll('.detector-slot')).find(s => s.classList.contains('hidden'));
      if (nextSlot) {
        nextSlot.classList.remove('hidden');
        // Forzar actualización de UI para que muestre el Empty State
        const ppeDetector = nextSlot.querySelector('ppe-detector') as any;
        if (ppeDetector && typeof ppeDetector.updateDetectorUI === 'function') {
          ppeDetector.updateDetectorUI();
        }
        updateScreensUI(); 
      }
    } 
  });

  btnRemove?.addEventListener('click', () => { 
    if (activeScreens > 1) { 
      const visibleSlots = Array.from(document.querySelectorAll('.detector-slot:not(.hidden)'));
      // Detener la fuente de video del Custom Element antes de ocultar el slot
      const lastVisibleSlot = visibleSlots[visibleSlots.length - 1];
      const ppeDetectorElement = lastVisibleSlot.querySelector('ppe-detector') as any;
      if (ppeDetectorElement && typeof ppeDetectorElement.stopDetectorSource === 'function') {
        ppeDetectorElement.stopDetectorSource();
      }
      visibleSlots[visibleSlots.length - 1].classList.add('hidden');
      updateScreensUI(); 
    } 
  });

</script>
</Layout>
