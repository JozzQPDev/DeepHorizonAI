---
interface Props {
  idPrefix?: string;
}
const { idPrefix = '' } = Astro.props;
const p = idPrefix;
---
<div id={`${p}modal-ip-cam`} class="absolute inset-0 z-100 items-center justify-center bg-black/80 hidden backdrop-blur-sm p-4">
  <div class="bg-[#0d1117] border border-white/10 p-6 rounded-xl shadow-2xl max-w-sm w-full font-mono">
    <h3 class="text-sm text-white mb-4 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12.55a11 11 0 0 1 14.08 0"></path><path d="M1.42 9a16 16 0 0 1 21.16 0"></path><circle cx="12" cy="20" r="2"></circle></svg>
      Vincular Cámara Inalámbrica
    </h3>
    <p class="text-[10px] text-gray-400 mb-4 leading-relaxed">
      1. En tu celular, entra a <b class="text-blue-400">vdo.ninja</b><br/>
      2. Toca en "Add your Camera to OBS"<br/>
      3. Copia el link generado y pégalo aquí:
    </p>
    
    <!-- Botón para Escanear QR -->
    <button id={`${p}btn-ip-scan`} class="w-full mb-3 px-3 py-2 bg-blue-500/10 hover:bg-blue-500/20 border border-blue-500/30 rounded text-[10px] text-blue-400 flex items-center justify-center gap-2 transition-all group/scan">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover/scan:scale-110 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="7" y1="7" x2="7.01" y2="7"></line><line x1="17" y1="7" x2="17.01" y2="7"></line><line x1="7" y1="17" x2="7.01" y2="17"></line><line x1="17" y1="17" x2="17.01" y2="17"></line><line x1="7" y1="12" x2="7.01" y2="12"></line><line x1="12" y1="7" x2="12.01" y2="7"></line><line x1="12" y1="12" x2="12.01" y2="12"></line><line x1="12" y1="17" x2="12.01" y2="17"></line><line x1="17" y1="12" x2="17.01" y2="12"></line></svg>
      <span id={`${p}scan-text`}>ESCANEAR CÓDIGO QR</span>
    </button>

    <input id={`${p}input-ip-url`} type="text" placeholder="https://vdo.ninja/?v=ID_DE_TU_CAMARA" class="w-full bg-black/40 border border-white/10 rounded px-3 py-2 text-[11px] text-blue-300 mb-4 focus:border-blue-500 outline-none" />
    
    <div class="flex gap-2">
      <button id={`${p}btn-ip-cancel`} class="flex-1 px-3 py-2 bg-white/5 hover:bg-white/10 rounded text-[10px] text-gray-400 transition-colors">
        CANCELAR
      </button>
      <button id={`${p}btn-ip-connect`} class="flex-1 px-3 py-2 bg-blue-600 hover:bg-blue-500 rounded text-[10px] text-white transition-colors font-bold tracking-widest">
        VINCULAR
      </button>
    </div>
  </div>
</div>