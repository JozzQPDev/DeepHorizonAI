<footer class="w-full shrink-0 flex items-center justify-between gap-x-4 px-6 pl-[calc(1.5rem+env(safe-area-inset-left))] pr-[calc(1.5rem+env(safe-area-inset-right))] py-2 pb-[calc(0.7rem+env(safe-area-inset-bottom))] lg:py-0 lg:h-8 border-t border-white/5 bg-[#0d1117]/95 backdrop-blur-md text-[9px] md:text-[10px] font-mono text-gray-500 z-50">
  <div class="flex gap-4">
    <span>ms: <b id="inf-ms" class="text-gray-300">—</b></span>
    <span class="hidden sm:inline">device: <b id="inf-dev" class="text-gray-300">—</b></span>
    <span class="hidden md:inline">res: <b id="inf-res" class="text-gray-300">—</b></span>
  </div>
  
  <!-- Contenedor dinámico para clases detectadas -->
  <div id="live-classes" class="hidden lg:flex items-center gap-1.5 overflow-hidden lg:px-3 h-4 border-l border-white/10"></div>

  <div class="flex items-center gap-4">
    <span class="hidden xs:inline text-gray-600 uppercase tracking-tighter">Sync: <b id="inf-ts" class="text-gray-400 font-normal">—</b></span>
    <span id="live-clock" class="text-blue-400/80 font-bold border-l border-white/10 pl-4 w-20 text-right">00:00:00</span>
  </div>
</footer>