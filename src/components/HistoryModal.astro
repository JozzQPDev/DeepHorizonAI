---
import "@fortawesome/fontawesome-free/css/all.min.css";
---
<div id="modal-overlay" class="fixed inset-0 z-[500] items-center justify-center bg-black/95 hidden backdrop-blur-sm p-4 md:p-8 transition-all duration-300">
  <div class="relative max-w-5xl w-full flex flex-col items-center animate-in zoom-in-95 duration-200">
    
    <!-- Cabecera del Modal -->
    <div class="w-full max-w-[90vw] flex justify-between items-end mb-3 px-1">
      <div class="flex flex-col">
        <span id="modal-class" class="text-red-500 font-mono text-xs font-bold uppercase tracking-widest">Alerta de Seguridad</span>
        <span id="modal-time" class="text-gray-500 font-mono text-[10px]">--:--:--</span>
      </div>
      <div class="flex gap-2">
        <button id="modal-download" title="Descargar Evidencia" class="p-2 bg-white/5 hover:bg-white/10 rounded-full text-blue-400 transition-colors border border-white/10">
          <i class="fa-solid fa-download"></i>
        </button>
        <button id="modal-close" class="p-2 bg-white/5 hover:bg-white/10 rounded-full text-gray-400 hover:text-white transition-colors border border-white/10">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>
    </div>

    <!-- Imagen con resplandor sutil de alerta -->
    <img id="modal-img" src="" class="max-w-[90vw] max-h-[75vh] rounded-lg shadow-2xl border border-white/10 object-contain shadow-red-500/5" />
    
    <div class="mt-6 text-center text-gray-500 text-[9px] font-mono uppercase tracking-[0.2em] opacity-40">
      Click en cualquier lugar para cerrar
    </div>
  </div>
</div>

<script>
  const overlay = document.getElementById('modal-overlay');
  const modalImg = document.getElementById('modal-img') as HTMLImageElement;
  const modalClass = document.getElementById('modal-class');
  const modalTime = document.getElementById('modal-time');
  const downloadBtn = document.getElementById('modal-download');
  const closeBtn = document.getElementById('modal-close');

  const closeModal = () => {
    overlay?.classList.replace('flex', 'hidden');
    if (modalImg) modalImg.src = '';
  };

  // Cerrar el modal al hacer clic en el fondo
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });

  closeBtn?.addEventListener('click', closeModal);

  downloadBtn?.addEventListener('click', () => {
    if (!modalImg.src) return;
    const link = document.createElement('a');
    link.href = modalImg.src;
    link.download = `alerta-epp-${modalClass?.textContent?.toLowerCase().replace(/\s+/g, '-')}-${modalTime?.textContent?.replace(/:/g, '')}.jpg`;
    link.click();
  });

  // Escuchar clics en las imágenes del historial para ampliarlas
  document.getElementById('history-list')?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const img = target.tagName === 'IMG' ? target as HTMLImageElement : null;
    
    if (img && modalImg && overlay) {
      modalImg.src = img.src;
      if (modalClass) modalClass.textContent = img.dataset.class || 'Alerta detectada';
      if (modalTime) modalTime.textContent = img.dataset.time || '';
      overlay.classList.replace('hidden', 'flex');
    }
  });
</script>