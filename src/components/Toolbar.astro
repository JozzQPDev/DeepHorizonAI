---
import "@fortawesome/fontawesome-free/css/all.min.css";
---
<!-- Importar la fuente Inter -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<header class="shrink-0 flex items-center justify-between px-4 h-11 border-b border-white/5 bg-[#0d1117]">

  <div class="flex items-center gap-2">
    <!-- Botón de Menú para Móviles -->
    <button id="btn-open-sidebar" class="lg:hidden p-2 text-gray-400 hover:text-white transition-colors active:scale-90">
      <i class="fa-solid fa-bars text-lg"></i>
    </button>
  </div>

  <div class="flex-1 flex items-center justify-between ml-4">
    <!-- Selector Dinámico de Pantallas -->
    <div class="hidden sm:flex items-center gap-3">
      <div class="flex items-center gap-2">
        <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">
          Monitores: <span id="active-count-text" class="text-blue-400">1</span>
        </span>
      </div>
      <div class="flex gap-1.5">
        <button id="btn-remove-screen" class="p-1.5 text-[10px] bg-red-500/10 hover:bg-red-500/20 text-red-500 rounded-md transition-all opacity-50 cursor-not-allowed border border-red-500/20" title="Quitar monitor">
          <i class="fa-solid fa-minus"></i>
        </button>
        <button id="btn-add-screen" class="px-3 py-1 text-[10px] bg-blue-600 hover:bg-blue-500 text-white rounded-md font-bold transition-all flex items-center gap-2 uppercase tracking-tight shadow-lg shadow-blue-900/20">
          <i class="fa-solid fa-plus text-[8px]"></i> Añadir 
        </button>
      </div>
    </div>

    <div id="api-dot" class="flex items-center gap-1.5 text-[10px] font-mono text-yellow-400">
      <span class="w-1.5 h-1.5 rounded-full bg-current inline-block"></span>
      <span id="api-label">conectando…</span>
    </div>
  </div>
</header>